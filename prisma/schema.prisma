generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  projects     Project[]
  customRates  CustomRate[]
}

model Project {
  id            String   @id @default(cuid())
  userId        String?
  name          String
  floorPlanUrl  String?
  furnitureData Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user           User?           @relation(fields: [userId], references: [id])
  quotes         Quote[]
  layoutVersions LayoutVersion[]
  rooms          Room[]
}

model Room {
  id          String   @id @default(cuid())
  projectId   String
  label       String
  roomType    String?
  boundingBox Json?
  areaSqft    Float?
  dimensions  Json?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Quote {
  id          String   @id @default(cuid())
  projectId   String
  rooms       Json
  rates       Json
  margin      Float    @default(0.10)
  totalAmount Float
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])
}

model DefaultRate {
  id          String @id @default(cuid())
  category    String
  itemName    String
  unitCost    Float
  unit        String
  description String?

  @@unique([category, itemName])
}

model CustomRate {
  id       String @id @default(cuid())
  userId   String
  category String
  itemName String
  unitCost Float
  unit     String
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, category, itemName])
}

model LayoutVersion {
  id        String   @id @default(cuid())
  projectId String
  name      String
  data      Json
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

